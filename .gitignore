# This file specifies intentionally untracked files

# Per-user config: personal paths + BrainMaster api_key/admin_token. Never commit;
# the app generates a clean one from DEFAULT_CONFIG on first run.
config.json

# Temporary files including undo
*~
*.bak
.DS_Store
#
__pycache__/
*.pyc
/.idea/
/.vs/
/books/
/data/*
!/data/README.md
!/data/README.en.md
/engines/
/env/
/old/
*.pgi
*.pgn
/chess_com/cache
/game1.ini
*.ini
/data - Copia
/pgn/spanish.ini
*.cko
*.cpo
/build/
/dist/
# Release build artifacts (prodotti da release.py / CI, non vanno versionati)
HiresChess-*.zip
HiresChess-*.dmg

# Position-stats disk cache (auto-rebuilt da position_stats.py)
*.idx

# Watch-mode (vision) debug artifacts: runtime captures written by
